# SourceTECH Environment Variables

# Flask secret key (generate a random string for production)
SECRET_KEY=your-secret-key-here

# PavTECH API URL
PAVTECH_API_URL=http://localhost:5000

# Database path
DATABASE=sourcetech.db

# Temp directory for file processing
TEMP_DIR=/tmp/sourcetech

# Admin password for the admin portal
ADMIN_PASSWORD=changeme

# SendGrid API key for email notifications
SENDGRID_API_KEY=your-sendgrid-api-key

# From email address for notifications
FROM_EMAIL=sourcetech@example.com

# ── DealTECH bridge ──────────────────────────────────────────────────────────
# Base URL of the DealTECH service. SourceTECH calls {DEALTECH_API_URL}/webhook/
# sourcetech after a vendor uploads, so DealTECH auto-checks the P1 data-received gate.
DEALTECH_API_URL=https://dealtech.onrender.com
# Shared secret for the DealTECH<->SourceTECH server-to-server API. MUST match
# DealTECH's WEBHOOK_SECRET / HUBSPOT webhook_secret exactly. When set, the
# /api/vendors* endpoints require it and outbound callbacks send it.
WEBHOOK_SECRET=
# Public base URL of THIS SourceTECH service (used to build absolute upload links
# returned to DealTECH). Falls back to the request host if unset.
PUBLIC_BASE_URL=https://sourcetech.onrender.com
